# --- Vercel (هنگام Build فرانت) ---
# در پروژه فرانت Vercel → Settings → Environment Variables → همه محیط‌ها (Production / Preview)
# بک‌اند روی Vercel (مخزن/پروژه API، مثلاً dokan): بدون اسلش آخر
VITE_API_BASE_URL=https://dokan.vercel.app
# اگر نام پروژهٔ API در Vercel متفاوت است (مثلاً smart7hub2026-del): همان دامنهٔ *.vercel.app را بگذارید

# --- بک‌اند API (Vercel Serverless یا Render و غیره) ---
NODE_ENV=production
JWT_SECRET=حداقل-۳۲-کاراکتر-تصادفی-اینجا
# مبدأ دقیق سایت فرانت (همان دامنه‌ای که کاربر در مرورگر باز می‌کند)
ALLOWED_ORIGINS=https://dokanyar.vercel.app
# اگر هنوز Failed to fetch و CORS: true بگذار تا هر https://*.vercel.app (شامل preview) مجاز شود
CORS_ALLOW_VERCEL_APP=true
RECAPTCHA_REQUIRED_IN_PROD=false
# PostgreSQL (اجباری در production) — مثال Render Postgres یا Neon:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/dokanyar?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/dokanyar

# ساده‌ترین حالت: فقط این یکی (به‌جای سه متغیر SEED_* جدا)
SEED_BOOTSTRAP=یک-رمز-قوی-حداقل-۱۶-کاراکتر

# یا جداگانه (اگر SEED_BOOTSTRAP نگذاشتی هر سه لازم‌اند):
# SEED_SUPERADMIN_PASSWORD=...
# SEED_RESET_CODE=...
# SEED_PENDING_USER_PASSWORD=...

# ثبت‌نام آزمایشی روی خوش‌آمد: پیش‌فرض روشن است. برای خاموش کردن:
# ALLOW_TRIAL_QUICK_SIGNUP=false

# اگر reCAPTCHA را فعال کردید:
# RECAPTCHA_SECRET_KEY=...

# --- HA / replica / بکاپ ابری (تنظیم سرویس Postgres، نه فقط env) ---
# Neon / Supabase / AWS RDS / Render Postgres: از پنل همان سرویس «branch»، «read replica»،
# «Point-in-time recovery» یا snapshot خودکار را فعال کنید — در کد Node قابل جایگزینی نیست.
# بکاپ فایلی (نیاز به pg_dump در PATH): اسکریپت‌های scripts/pg-backup.ps1 و scripts/pg-backup.sh
# همزمانی ذخیره: اگر دو درخواست همزمان همان داده را بنویسند، API ممکن است 409 با STORAGE_CONFLICT برگرداند.

# --- Auto backup JSON از state (همان قبلی) ---
# AUTO_BACKUP_INTERVAL_HOURS=24
# AUTO_BACKUP_KEEP_COUNT=30
# نگهداری فایل‌های platform-*.json / .manifest.json / .json.gz (هم‌پوشان با بالا):
# PLATFORM_BACKUP_KEEP=30
# کپی فشردهٔ اضافه کنار .json: PLATFORM_BACKUP_GZIP=true

# رمزنگاری فایل بکاپ روی دیسک (AES-256-GCM): یکی از این دو را بگذارید
# PLATFORM_BACKUP_ENCRYPTION_KEY=۶۴-کاراکتر-هگز-۳۲-بایت
# PLATFORM_BACKUP_PASSPHRASE=عبارت-قوی-حداقل-۸-کاراکتر
# اگر رمز فعال است و نمی‌خواهید نسخهٔ plaintext روی دیسک بماند: PLATFORM_BACKUP_PLAINTEXT_ALSO=false

# آپلود خودکار بکاپ به S3 / MinIO (اختیاری)
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=eu-central-1
# S3_BACKUP_BUCKET=نام-باکت
# S3_BACKUP_PREFIX=dokanyar-backups
# برای MinIO: S3_ENDPOINT=https://minio.example.com S3_FORCE_PATH_STYLE=true

# pg_dump زمان‌بندی‌شده (نیاز به pg_dump در PATH؛ مکمل JSON)
# PG_DUMP_INTERVAL_HOURS=24
# PG_DUMP_KEEP=14
# PG_DUMP_BIN=pg_dump

# سقف حجم/timeout اسنپ‌شات HTTP (دانلود ابرادمین)
# PLATFORM_SNAPSHOT_MAX_BYTES=100663296
# PLATFORM_SNAPSHOT_TIMEOUT_MS=180000

# بازیابی پلتفرم از UI: حداکثر حجم body JSON
# API_JSON_LIMIT=48mb
# PLATFORM_RESTORE_MAX_BYTES=125829120
# عبارت تأیید سفارشی (پیش‌فرض DOKANYAR-AF-RESTORE-PLATFORM)
# MASTER_RESTORE_CONFIRM_PHRASE=DOKANYAR-AF-RESTORE-PLATFORM

# اعتبارسنجی مشتری روی PUT /api/state و فروش: شماره تکراری (غیرآرشیو) → 409؛ در Postgres ایندکس یکتای جزئی روی (shop_code, phone_key) برای ردیف‌های غیرآرشیو
